<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Required to read image files in the background -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_app_logo6"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppMailing"
        tools:targetApi="31">

        <!-- HOME SCREEN = LAUNCHER -->
        <activity
            android:name=".HomeScreen"
            android:exported="true"
            android:windowSoftInputMode="adjustPan">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- Products -->
        <activity android:name=".TheProducts.ProductsActivity" />
        <activity android:name=".TheProducts.AddProductActivity" />
        <activity android:name=".TheProducts.ProductDetailActivity" />

        <!-- Contacts -->
        <activity android:name=".TheContact.ContactsActivity" />
        <activity android:name=".TheContact.AddContactActivity" />
        <activity android:name=".TheContact.ContactDetailActivity" />

        <!-- Stats -->
        <activity android:name=".statistique.StatistiqueActivity" />

        <!-- Campaign -->
        <activity android:name=".Thecampaing.CampaignActivity" />
        <activity android:name=".Thecampaing.CampaignDetailActivity" />

    </application>

</manifest>