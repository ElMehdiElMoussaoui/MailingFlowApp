<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:layout_marginTop="15dp">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="2dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                app:tint="#555555" /> <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/title_add_contact"
            android:textColor="#1A1A2E"
            android:textSize="18sp"
            android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnSaveIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="end"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_check"
                app:tint="#2979FF" /> </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#EBEBEB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp"
                        android:orientation="horizontal">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_star" app:tint="#2979FF" /> <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/section_new_recipient"
                        android:textColor="#1A1A2E" android:textSize="17sp" android:textStyle="bold" />
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:text="@string/new_recipient_desc"
                        android:textColor="#888888" android:textSize="13sp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:layout_marginBottom="4dp"
                        android:orientation="horizontal">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@drawable/ic_person" app:tint="#2979FF" /> <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/label_full_name" android:textSize="13sp"
                        android:textColor="#444444" android:textStyle="bold" android:layout_marginStart="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" *" android:textSize="13sp" android:textColor="#F44336" />
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutFullName"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="#E0E0E0" app:hintEnabled="false">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etFullName" android:layout_width="match_parent"
                            android:layout_height="52dp" android:hint="@string/hint_full_name"
                            android:inputType="textPersonName" android:imeOptions="actionNext"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/helper_full_name" android:textSize="11sp"
                        android:textColor="#AAAAAA" android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:layout_marginBottom="4dp"
                        android:orientation="horizontal">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@drawable/ic_email" app:tint="#2979FF" /> <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/label_email" android:textSize="13sp"
                        android:textColor="#444444" android:textStyle="bold" android:layout_marginStart="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" *" android:textSize="13sp" android:textColor="#F44336" />
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutEmail"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="#E0E0E0" app:hintEnabled="false">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail" android:layout_width="match_parent"
                            android:layout_height="52dp" android:hint="@string/hint_email"
                            android:inputType="textEmailAddress" android:imeOptions="actionNext"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/helper_email" android:textSize="11sp"
                        android:textColor="#AAAAAA" android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:layout_marginBottom="4dp"
                        android:orientation="horizontal">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@drawable/ic_phone" app:tint="#2979FF" /> <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/label_phone"
                        android:textSize="13sp" android:textColor="#444444" android:textStyle="bold"
                        android:layout_marginStart="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/label_optional" android:textSize="11sp"
                            android:textColor="#AAAAAA" />
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutPhone"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="#E0E0E0" app:hintEnabled="false">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPhone" android:layout_width="match_parent"
                            android:layout_height="52dp" android:hint="@string/hint_phone"
                            android:inputType="phone" android:imeOptions="actionDone"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/helper_phone" android:textSize="11sp"
                        android:textColor="#AAAAAA" android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/bg_privacy_note" android:gravity="center_vertical"
                        android:orientation="horizontal" android:padding="14dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp"
                            android:src="@drawable/ic_privacy" app:tint="#2979FF" /> <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/privacy_note_title" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="#1A1A2E" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/privacy_note_desc" android:textSize="12sp"
                            android:textColor="#666666" android:layout_marginTop="2dp" />
                    </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveContact"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#2979FF"
                android:text="@string/btn_save_contact"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="26dp" />

            <TextView
                android:id="@+id/tvCancel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:padding="12dp"
                android:text="@string/btn_cancel_return"
                android:textColor="#888888"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>