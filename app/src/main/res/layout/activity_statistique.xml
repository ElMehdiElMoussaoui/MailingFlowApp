<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- ── Header ─────────────────────────────────────────────────────────── -->
    <RelativeLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            app:tint="#333333" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Statistics"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnCalendar"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_calendar"
            app:tint="#333333" />
    </RelativeLayout>

    <!-- ── Scrollable content ─────────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/headerBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Period header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Performance Period"
                        android:textColor="#888888"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last 7 Days"
                        android:textColor="#000000"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDateRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/rounded_border"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Oct 20 — Oct 27"
                    android:textColor="#555555"
                    android:textSize="12sp" />
            </RelativeLayout>

            <!-- ── KPI row ─────────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- Open Rate -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/card_border"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_view"
                            app:tint="#2196F3" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="OPEN RATE"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvOpenRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="0%"
                            android:textColor="#000000"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Click Rate -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/card_border"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_mylocation"
                            app:tint="#F44336" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="CLICK RATE"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvClickRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="0%"
                            android:textColor="#000000"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Success Rate -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/card_border"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/checkbox_on_background"
                            app:tint="#4CAF50" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="SUCCESS"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvSuccessPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="0%"
                            android:textColor="#000000"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ── Engagement Trends bar chart ───────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Engagement Trends"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Email opens vs link clicks this week"
                        android:textColor="#888888"
                        android:textSize="12sp" />

                    <!-- Bar chart (5 day groups) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="130dp"
                        android:layout_marginTop="16dp"
                        android:gravity="bottom"
                        android:orientation="horizontal"
                        android:weightSum="5">

                        <!-- Mon -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:gravity="bottom|center_horizontal"
                            android:orientation="vertical">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:gravity="bottom" android:orientation="horizontal">
                                <View android:id="@+id/monOpen"
                                    android:layout_width="10dp" android:layout_height="15dp"
                                    android:layout_marginEnd="2dp" android:background="#2196F3"/>
                                <View android:id="@+id/monClick"
                                    android:layout_width="10dp" android:layout_height="5dp"
                                    android:background="#4DD0E1"/>
                            </LinearLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="Mon"
                                android:textColor="#AAAAAA" android:textSize="10sp"/>
                        </LinearLayout>

                        <!-- Tue -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:gravity="bottom|center_horizontal"
                            android:orientation="vertical">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:gravity="bottom" android:orientation="horizontal">
                                <View android:id="@+id/tueOpen"
                                    android:layout_width="10dp" android:layout_height="22dp"
                                    android:layout_marginEnd="2dp" android:background="#2196F3"/>
                                <View android:id="@+id/tueClick"
                                    android:layout_width="10dp" android:layout_height="8dp"
                                    android:background="#4DD0E1"/>
                            </LinearLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="Tue"
                                android:textColor="#AAAAAA" android:textSize="10sp"/>
                        </LinearLayout>

                        <!-- Wed -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:gravity="bottom|center_horizontal"
                            android:orientation="vertical">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:gravity="bottom" android:orientation="horizontal">
                                <View android:id="@+id/wedOpen"
                                    android:layout_width="10dp" android:layout_height="30dp"
                                    android:layout_marginEnd="2dp" android:background="#2196F3"/>
                                <View android:id="@+id/wedClick"
                                    android:layout_width="10dp" android:layout_height="15dp"
                                    android:background="#4DD0E1"/>
                            </LinearLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="Wed"
                                android:textColor="#AAAAAA" android:textSize="10sp"/>
                        </LinearLayout>

                        <!-- Thu -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:gravity="bottom|center_horizontal"
                            android:orientation="vertical">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:gravity="bottom" android:orientation="horizontal">
                                <View android:id="@+id/thuOpen"
                                    android:layout_width="10dp" android:layout_height="25dp"
                                    android:layout_marginEnd="2dp" android:background="#2196F3"/>
                                <View android:id="@+id/thuClick"
                                    android:layout_width="10dp" android:layout_height="12dp"
                                    android:background="#4DD0E1"/>
                            </LinearLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="Thu"
                                android:textColor="#AAAAAA" android:textSize="10sp"/>
                        </LinearLayout>

                        <!-- Fri -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:gravity="bottom|center_horizontal"
                            android:orientation="vertical">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:gravity="bottom" android:orientation="horizontal">
                                <View android:id="@+id/friOpen"
                                    android:layout_width="10dp" android:layout_height="20dp"
                                    android:layout_marginEnd="2dp" android:background="#2196F3"/>
                                <View android:id="@+id/friClick"
                                    android:layout_width="10dp" android:layout_height="10dp"
                                    android:background="#4DD0E1"/>
                            </LinearLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="Fri"
                                android:textColor="#AAAAAA" android:textSize="10sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Legend -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">
                        <View android:layout_width="10dp" android:layout_height="10dp"
                            android:layout_marginEnd="5dp" android:layout_gravity="center_vertical"
                            android:background="#2196F3"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp" android:text="Opens"
                            android:textColor="#666666" android:textSize="12sp"/>
                        <View android:layout_width="10dp" android:layout_height="10dp"
                            android:layout_marginEnd="5dp" android:layout_gravity="center_vertical"
                            android:background="#4DD0E1"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Clicks" android:textColor="#666666" android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Delivery Status donut ──────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivery Status"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Breakdown of delivery vs bounce rates"
                        android:textColor="#888888"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Donut chart (simulated with nested CardViews) -->
                        <RelativeLayout
                            android:layout_width="130dp"
                            android:layout_height="130dp">

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                app:cardBackgroundColor="#2196F3"
                                app:cardCornerRadius="65dp"
                                app:cardElevation="0dp" />

                            <androidx.cardview.widget.CardView
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                android:layout_centerInParent="true"
                                app:cardBackgroundColor="#FFFFFF"
                                app:cardCornerRadius="45dp"
                                app:cardElevation="0dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical">
                                    <TextView
                                        android:id="@+id/tvDonutPercent"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0%"
                                        android:textColor="#000000"
                                        android:textSize="16sp"
                                        android:textStyle="bold" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Success"
                                        android:textColor="#888888"
                                        android:textSize="11sp" />
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>
                        </RelativeLayout>

                        <!-- Donut legend -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">
                                <View android:layout_width="10dp" android:layout_height="10dp"
                                    android:layout_marginEnd="8dp" android:background="#2196F3"/>
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:text="Delivered"
                                    android:textColor="#555555" android:textSize="13sp"/>
                                <TextView
                                    android:id="@+id/tvDeliveredCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#000000"
                                    android:textSize="13sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical">
                                <View android:layout_width="10dp" android:layout_height="10dp"
                                    android:layout_marginEnd="8dp" android:background="#EF5350"/>
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:text="Bounced"
                                    android:textColor="#555555" android:textSize="13sp"/>
                                <TextView
                                    android:id="@+id/tvBouncedCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#000000"
                                    android:textSize="13sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:layout_marginTop="8dp">
                                <TextView android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Total sent:"
                                    android:textColor="#AAAAAA" android:textSize="11sp"/>
                            </LinearLayout>
                            <TextView
                                android:id="@+id/tvTotalEmailsSent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#2196F3"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Bottom navigation ──────────────────────────────────────────────── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="8dp"
        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="@color/bottom_nav_colors"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>