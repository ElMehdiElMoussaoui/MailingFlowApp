<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Campaign name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Campaign Name"
            android:textColor="#555555"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/input_border"
            android:hint="e.g. Summer Promo"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textColor="#000000"
            android:textColorHint="#BBBBBB"
            android:textSize="14sp"
            android:layout_marginBottom="14dp" />

        <!-- Product selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Product"
            android:textColor="#555555"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etSearchProduct"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/input_border"
            android:hint="Search product..."
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textColor="#000000"
            android:textColorHint="#BBBBBB"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerProduct"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/input_border"
            android:layout_marginBottom="14dp" />

        <!-- Email subject -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email Subject"
            android:textColor="#555555"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etSubject"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/input_border"
            android:hint="e.g. Don't miss our summer sale!"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textColor="#000000"
            android:textColorHint="#BBBBBB"
            android:textSize="14sp"
            android:layout_marginBottom="14dp" />

        <!-- Image picker section -->
        <LinearLayout
            android:id="@+id/imagePickerSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Campaign Image (optional)"
                android:textColor="#555555"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <!-- Image preview -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvImagePreview"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/ivSelectedImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#F0F0F0"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery" />
            </androidx.cardview.widget.CardView>

            <!-- Pick image button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPickImage"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/button_outline_blue"
                android:text="Choose Image"
                android:textAllCaps="false"
                android:textColor="#2196F3"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>